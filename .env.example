# 楽天ウェブサービス アプリID（UUID形式）
# 取得先: https://webservice.rakuten.co.jp/
RAKUTEN_APP_ID=your_rakuten_application_id
RAKUTEN_ACCESS_KEY=your_rakuten_access_key
RAKUTEN_affiliate_id=your_affiliate_id

# Neon PostgreSQL 接続文字列
# 取得先: https://console.neon.tech/ → プロジェクト → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

PORT=3000
